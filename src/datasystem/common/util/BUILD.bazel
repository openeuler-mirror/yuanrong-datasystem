alias(name = "timer", actual = ":common_util_impl")
alias(name = "locks", actual = ":common_util_impl")
alias(name = "thread", actual = ":common_util_impl")
alias(name = "random_data", actual = ":common_util_impl")
alias(name = "uuid_generator", actual = ":common_util_impl")
alias(name = "net_util", actual = ":common_util_impl")
alias(name = "template_util", actual = ":common_util_impl")
alias(name = "wait_post", actual = ":common_util_impl")
alias(name = "fd_pass", actual = ":common_util_impl")
alias(name = "fd_manager", actual = ":common_util_impl")
alias(name = "memory", actual = ":common_util_impl")
alias(name = "version", actual = ":common_util_impl")
alias(name = "uri", actual = ":common_util_impl")
alias(name = "thread_local", actual = ":common_util_impl")
alias(name = "dlutils", actual = ":common_util_impl")
alias(name = "sensitive_value", actual = ":common_util_impl")
alias(name = "ssl_authorization", actual = ":common_util_impl")
