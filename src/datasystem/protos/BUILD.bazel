# --- object_posix brpc adapter (genrule + cc_library) ---
genrule(
    name = "object_posix_brpc_gen",
    srcs = [
        "object_posix.proto",
        "rpc_option.proto",
        "utils.proto",
        "p2p_subscribe.proto",
        "meta_transport.proto",
    ],
    tools = [
        "@com_google_protobuf//:protoc",
        "//src/datasystem/common/rpc/plugin_generator:rpc_plugin",
    ],
    outs = [
        "object_posix.brpc.pb.h",
        "object_posix.brpc.pb.cc",
        "object_posix.brpc.stub.pb.h",
        "object_posix.brpc.stub.pb.cc",
        "object_posix.irpc.pb.h",
    ],
    cmd = """
        PROTOC=$(location @com_google_protobuf//:protoc)
        PLUGIN=$(location //src/datasystem/common/rpc/plugin_generator:rpc_plugin)
        OUT_DIR=$$(dirname $(location object_posix.brpc.pb.h))
        PROTO_ROOT=$$(cd $$(dirname $(location object_posix.proto))/../../.. && pwd)
        # PROTO_ROOT is execroot/yuanrong-datasystem. The google protobuf well-known
        # types live at external/com_google_protobuf/src relative to execroot.
        # However, in the sandbox, external/ may only contain bazel_tools.
        # Use readlink to resolve protoc's real path and derive the include.
        PROTOC_REAL=$$(readlink -f $$PROTOC)
        GOOGLE_PROTOBUF_SRC=$$(dirname $$PROTOC_REAL)/../../../../../external/com_google_protobuf/src
        TMPD=$$(mktemp -d)
        $$PROTOC \\
            -I$$PROTO_ROOT/src \\
            -I$$GOOGLE_PROTOBUF_SRC \\
            --plugin=protoc-gen-rpc=$$PLUGIN \\
            --rpc_out=$$TMPD \\
            datasystem/protos/object_posix.proto
        GEN=$$TMPD/datasystem/protos
        cp $$GEN/object_posix.brpc.pb.h $$GEN/object_posix.brpc.pb.cc \
           $$GEN/object_posix.brpc.stub.pb.h $$GEN/object_posix.brpc.stub.pb.cc \
           $$GEN/object_posix.irpc.pb.h \
           $$OUT_DIR/
        rm -rf $$TMPD
    """,
)

cc_library(
    name = "object_posix_brpc",
    srcs = [":object_posix_brpc_gen"],
    hdrs = [":object_posix_brpc_gen"],
    strip_include_prefix = ".",
    include_prefix = "datasystem/protos",
    deps = [
        ":object_posix_cc_proto",
        ":rpc_option_cc_proto",
        ":utils_cc_proto",
        ":p2p_subscribe_cc_proto",
        ":meta_transport_cc_proto",
        "@com_github_apache_brpc//:brpc",
        "//include/datasystem/utils:utils_headers",
        "//src/datasystem/common/rpc:brpc_server_unary_writer_reader",
        "//src/datasystem/common/rpc:rpc_message",
        "//src/datasystem/common/rpc:rpc_options",
        "//src/datasystem/common/rpc:rpc_server_stream_base",
        "//src/datasystem/common/rpc:rpc_stub",
        "//src/datasystem/common/rpc:rpc_unary_client_impl",
        "@com_google_protobuf//:protobuf",
    ],
)
