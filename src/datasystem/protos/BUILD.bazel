# --- brpc adapter test (genrule + cc_library) ---
genrule(
    name = "generic_service_brpc_gen",
    srcs = [
        "generic_service.proto",
    ],
    tools = [
        "@com_google_protobuf//:protoc",
        "//src/datasystem/common/rpc/plugin_generator:rpc_plugin",
    ],
    outs = [
        "generic_service.brpc.pb.h",
        "generic_service.brpc.pb.cc",
        "generic_service.brpc.stub.pb.h",
        "generic_service.brpc.stub.pb.cc",
        "generic_service.irpc.pb.h",
    ],
    cmd = """
        PROTOC=$(location @com_google_protobuf//:protoc)
        PLUGIN=$(location //src/datasystem/common/rpc/plugin_generator:rpc_plugin)
        OUT_DIR=$$(dirname $(location generic_service.brpc.pb.h))
        PROTO_ROOT=$$(cd $$(dirname $(location generic_service.proto))/../../.. && pwd)
        # Use -I pointing to src/ so proto appears as datasystem/protos/generic_service.proto
        # This ensures fileName = datasystem/protos/generic_service, producing correct
        # include paths like datasystem/protos/generic_service.pb.h that match cc_proto_library.
        # Generate to a temp dir then flatten to declared output names.
        TMPD=$$(mktemp -d)
        $$PROTOC \\
            -I$$PROTO_ROOT/src \\
            --plugin=protoc-gen-rpc=$$PLUGIN \\
            --rpc_out=$$TMPD \\
            datasystem/protos/generic_service.proto
        # Plugin generates under datasystem/protos/ subdirectory.
        # Move to flat output names expected by Bazel genrule.
        GEN=$$TMPD/datasystem/protos
        cp $$GEN/generic_service.brpc.pb.h $$GEN/generic_service.brpc.pb.cc \
           $$GEN/generic_service.brpc.stub.pb.h $$GEN/generic_service.brpc.stub.pb.cc \
           $$GEN/generic_service.irpc.pb.h \
           $$OUT_DIR/
        rm -rf $$TMPD
    """,
)

cc_library(
    name = "generic_service_brpc",
    srcs = [":generic_service_brpc_gen"],
    hdrs = [":generic_service_brpc_gen"],
    strip_include_prefix = ".",
    include_prefix = "datasystem/protos",
    deps = [
        ":generic_service_cc_proto",
        ":rpc_option_cc_proto",
        "@com_github_apache_brpc//:brpc",
        "//include/datasystem/utils:utils_headers",
        "//src/datasystem/common/rpc:brpc_server_unary_writer_reader",
        "//src/datasystem/common/rpc:rpc_message",
        "//src/datasystem/common/rpc:rpc_options",
        "//src/datasystem/common/rpc:rpc_server_stream_base",
        "//src/datasystem/common/rpc:rpc_stub",
        "//src/datasystem/common/rpc:rpc_unary_client_impl",
        "@com_google_protobuf//:protobuf",
    ],
)

