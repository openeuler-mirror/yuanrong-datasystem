load("//bazel:build_defs.bzl", "ds_cc_test")

package(default_visibility = ["//visibility:public"])

# All device tests require NPU hardware and are manual only.
# Tests using ascend_device_manager_mock.cpp (which includes binmock.h with
# a relative path "../common/binmock/binmock.h") need -Itests/st copts.

MOCK_COPTS = ["-Itests/st"]

DEVICE_COMMON_DEPS = [
    "//src/datasystem/client:datasystem",
    "//src/datasystem/client/hetero_cache:hetero_client",
    "//src/datasystem/common/inject:common_inject",
    "//src/datasystem/common/log:common_log",
    "//src/datasystem/common/util:status_helper",
    "//tests/st:st_common",
    "//tests/st/client/object_cache:oc_client_common",
]

ds_cc_test(
    name = "acl_resource_manager_fallback_test",
    srcs = [
        "acl_resource_manager_fallback_test.cpp",
        "mock/ascend_device_manager_mock.cpp",
    ],
    copts = MOCK_COPTS,
    tags = ["manual"],
    deps = DEVICE_COMMON_DEPS + [
        "//src/datasystem/common/device/ascend:acl_resource_manager",
        "//tests/common/binmock",
    ],
)

