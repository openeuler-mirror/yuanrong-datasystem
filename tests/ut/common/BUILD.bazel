    deps = [
        "//src/datasystem/common/kvstore/etcd:etcd_constants",
        "//src/datasystem/common/topology:common_topology",
        "//src/datasystem/protos:hash_ring_cc_proto",
        "//tests/ut:ut_common",
        "//tests/ut/common:topology_test_common",
    ],
)

ds_cc_test(
    name = "cluster_registry_test",
    srcs = ["topology/cluster_registry_test.cpp"],
    deps = [
        "//src/datasystem/common/kvstore/etcd:etcd_constants",
        "//src/datasystem/common/kvstore/etcd:etcd_store",
        "//src/datasystem/common/topology:common_topology",
        "//tests/ut:ut_common",
        "//tests/ut/common:topology_test_common",
    ],
)

ds_cc_test(
    name = "cluster_membership_test",
    srcs = ["topology/cluster_membership_test.cpp"],
    deps = [
        "//src/datasystem/common/kvstore/etcd:etcd_constants",
        "//src/datasystem/common/kvstore/etcd:etcd_store",
