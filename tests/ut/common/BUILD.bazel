        "//tests/ut/common:topology_test_common",
    ],
)

ds_cc_test(
    name = "worker_directory_test",
    srcs = ["topology/worker_directory_test.cpp"],
    deps = [
        "//src/datasystem/common/topology:common_topology",
        "//src/datasystem/common/util:status_helper",
        "//tests/ut:ut_common",
    ],
)

ds_cc_test(
    name = "topology_change_handler_test",
    srcs = ["topology/topology_change_handler_test.cpp"],
