load("//bazel:build_defs.bzl", "ds_cc_test")

package(default_visibility = ["//visibility:public"])

ds_cc_test(
    name = "zmq_metrics_test",
    srcs = ["zmq_metrics_test.cpp"],
    deps = [
        "//src/datasystem/common/metrics:common_metrics",
        "//src/datasystem/common/rpc/zmq:zmq_constants",
        "//src/datasystem/common/rpc/zmq:zmq_network_errno",
        "//tests/ut:ut_common",
    ],
)

ds_cc_test(
    name = "timeout_duration_test",
    srcs = ["timeout_duration_test.cpp"],
    deps = [
        # status_helper (via timeout_duration) calls Trace in status.cpp; pull trace.cpp from common_log.
        "//src/datasystem/common/log:common_log",
        "//src/datasystem/common/rpc:timeout_duration",
    ],
)

ds_cc_test(
    name = "zmq_trace_sampling_meta_test",
    srcs = ["zmq_trace_sampling_meta_test.cpp"],
    deps = [
        "//src/datasystem/common/rpc/zmq:zmq_common",
        "//src/datasystem/common/log:log_sampler",
        "//tests/ut:ut_common",
    ],
)
