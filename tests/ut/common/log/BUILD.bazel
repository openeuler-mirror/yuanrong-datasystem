load("//bazel:build_defs.bzl", "ds_cc_test")

package(default_visibility = ["//visibility:public"])

# 失败处理器测试
ds_cc_test(
    name = "failure_handler_test",
    srcs = ["failure_handler_test.cpp"],
    deps = [
        "//src/datasystem/common/log:common_log",
        "//src/datasystem/common/log:failure_handler",
        "//tests/ut:ut_common",
    ],
)

# 硬盘导出器测试
