    name = "hard_disk_exporter_test",
    srcs = ["hard_disk_exporter_test.cpp"],
    deps = [
        "//src/datasystem/common/log:common_log",
        "//src/datasystem/common/metrics:common_metrics",
        "//src/datasystem/common/metrics/hard_disk_exporter",
        "//tests/ut:ut_common",
    ],
)

# 日志性能测试
ds_cc_test(
    name = "log_performance_test",
