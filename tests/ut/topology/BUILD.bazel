    deps = [
        "//src/datasystem/common/kvstore/etcd:etcd_constants",
        "//src/datasystem/topology:topology",
        "//src/datasystem/protos:hash_ring_cc_proto",
        "//tests/ut:ut_common",
        "//tests/ut/topology:topology_test_common",
    ],
)

ds_cc_test(
    name = "cluster_registry_test",
    srcs = ["cluster_registry_test.cpp"],
    deps = [
        "//src/datasystem/common/kvstore/etcd:etcd_constants",
        "//src/datasystem/common/kvstore/etcd:etcd_store",
        "//src/datasystem/topology:topology",
        "//tests/ut:ut_common",
        "//tests/ut/topology:topology_test_common",
    ],
)

ds_cc_test(
    name = "cluster_membership_test",
    srcs = ["cluster_membership_test.cpp"],
    deps = [
        "//src/datasystem/common/kvstore/etcd:etcd_constants",
        "//src/datasystem/common/kvstore/etcd:etcd_store",
        "//src/datasystem/topology:topology",
        "//tests/ut:ut_common",
        "//tests/ut/topology:topology_test_common",
    ],
)

ds_cc_test(
    name = "worker_directory_test",
    srcs = ["worker_directory_test.cpp"],
    deps = [
        "//src/datasystem/topology:topology",
        "//src/datasystem/common/util:status_helper",
        "//tests/ut:ut_common",
    ],
)

ds_cc_test(
    name = "topology_change_handler_test",
    srcs = ["topology_change_handler_test.cpp"],
    deps = [
        "//src/datasystem/common/kvstore/etcd:etcd_constants",
