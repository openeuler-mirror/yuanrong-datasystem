@@ -195,4 +197,8 @@
-execute_process(
-    COMMAND bash -c "git rev-parse --short HEAD | tr -d '\n'"
-    OUTPUT_VARIABLE BRAFT_REVISION
-)
+# Release archives have no .git metadata. Allow the embedding project to
+# provide a stable revision instead of inheriting an unrelated parent repo.
+if(NOT BRAFT_REVISION)
+    execute_process(
+        COMMAND bash -c "git rev-parse --short HEAD | tr -d '\n'"
+        OUTPUT_VARIABLE BRAFT_REVISION
+    )
+endif()
