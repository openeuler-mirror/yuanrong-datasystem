+// calc filename according to timestamp and file extension if exists.
+// e.g. calc_filename("logs/mylog.txt, 2024-10-21 15:30:45) => "logs/mylog.20241021153045.txt".
+template <typename Mutex>
+SPDLOG_INLINE filename_t rotating_file_sink<Mutex>::calc_filename(const filename_t &filename,
+                                                                  std::tm time_tm) {
+    filename_t basename;
+    filename_t ext;
+    std::tie(basename, ext) = details::file_helper::split_by_extension(filename);
+
+    std::ostringstream oss;
+    oss << basename << "." << std::put_time(&time_tm, "%Y%m%d%H%M%S") << ext;
+    return oss.str();
+}
